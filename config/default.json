{
  "line": {
    "channelSecret": "",
    "channelAccessToken": ""
  },
  "server": {
    "port": 3100,
    "webhookPath": "/line/webhook"
  },
  "plugins": {
    "dir": "./plugins",
    "enabled": [
      "fitness",
      "niujiu",
      "todo",
      "routines",
      "work",
      "travel"
    ]
  },
  "scheduler": {
    "httpTrigger": true,
    "httpPath": "/api/cron"
  },
  "providers": {
    "db": {
      "type": "sqlite",
      "dir": "./data",
      "mode": "isolated"
    },
    "llm": {
      "type": "luna",
      "baseUrl": "http://localhost:18797",
      "timeout": 30000
    }
  }
}
