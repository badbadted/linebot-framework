{
  "name": "linebot-framework",
  "version": "0.1.0",
  "description": "Reusable LINE BOT framework — regex router + plugin architecture + scheduled push",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "start:luna": "CONFIG=config/luna.json node src/index.js",
    "dev": "node --watch src/index.js",
    "dev:luna": "CONFIG=config/luna.json node --watch src/index.js",
    "setup": "node bin/setup.js"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "better-sqlite3": "^12.10.0",
    "express": "^4.21.0",
    "firebase-admin": "^13.10.0",
    "node-cron": "^3.0.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
